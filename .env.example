# ============================================
# Echo — environment variables
# ============================================
# Copy this file to .env.local and fill in real values.
# Never commit .env.local. Server-side keys go in the
# Convex dashboard, NOT in the Vite bundle.

# ----- Frontend (Vite, public) -----
# These end up in the browser bundle. Only put public values here.
VITE_PRIVY_APP_ID=
VITE_CONVEX_URL=
VITE_MORPH_HOODI_RPC_URL=https://rpc-hoodi.morph.network
VITE_MORPH_HOODI_CHAIN_ID=2910
VITE_MORPH_HOODI_EXPLORER=https://explorer-hoodi.morph.network
VITE_USDC_ADDRESS=0x1178341838B764dCfFA5BCEAb1d41443Fd71a227
VITE_AGENT_WALLET_ADDRESS=
VITE_ECHO_DELEGATOR_ADDRESS=

# ----- Convex (server-side, set in Convex dashboard) -----
# Do NOT prefix with VITE_. These never reach the browser.
PRIVY_APP_SECRET=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_HOPE=
ELEVENLABS_VOICE_ID_MARK=
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@pay-echo.space
AGENT_PRIVATE_KEY=
# Set once we deploy the delegator contract:
ECHO_DELEGATOR_ADDRESS=
